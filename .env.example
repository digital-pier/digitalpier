# Copy this file to .env for local development, or set these
# values in the Hostinger hPanel under Advanced > Node.js > Environment.
# Do NOT commit the real .env (it is gitignored).

# Port is provided automatically by Hostinger/Passenger.
# Only set this for local development.
PORT=3000

# SMTP (ProtonMail Business example)
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=rick.lowe@digitalpier.dev
SMTP_PASS=your-proton-smtp-token

# Contact form addresses
CONTACT_FROM_EMAIL=rick.lowe@digitalpier.dev
CONTACT_TO_EMAIL=rick.lowe@digitalpier.dev
